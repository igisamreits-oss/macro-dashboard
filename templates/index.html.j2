<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="robots" content="noindex, nofollow">
<title>Global REIT Macro Dashboard</title>
<style>
:root {
  --bg: #0f172a;
  --panel: #1e293b;
  --panel-2: #334155;
  --border: #475569;
  --text: #f1f5f9;
  --text-dim: #94a3b8;
  --accent: #38bdf8;
  --good: #4ade80;
  --bad: #f87171;
  --warn: #fbbf24;
  --neutral: #cbd5e1;
}
* { box-sizing: border-box; }
body {
  margin: 0; padding: 0;
  font-family: -apple-system, BlinkMacSystemFont, "Pretendard", "Segoe UI", Roboto, sans-serif;
  background: var(--bg); color: var(--text);
  font-size: 14px; line-height: 1.5;
}
.container { max-width: 1600px; margin: 0 auto; padding: 24px; }
header {
  display: flex; justify-content: space-between; align-items: baseline;
  padding-bottom: 16px; margin-bottom: 24px;
  border-bottom: 1px solid var(--border);
}
header h1 { margin: 0; font-size: 24px; font-weight: 700; letter-spacing: -0.02em; }
header .meta { color: var(--text-dim); font-size: 13px; }
header .meta strong { color: var(--accent); }

section { margin-bottom: 32px; }
section h2 {
  font-size: 16px; font-weight: 600; margin: 0 0 12px 0;
  color: var(--text); letter-spacing: -0.01em;
  display: flex; align-items: center; gap: 8px;
}
section h2::before {
  content: ""; width: 3px; height: 16px; background: var(--accent); border-radius: 2px;
}
section h2 small { color: var(--text-dim); font-weight: 400; font-size: 12px; margin-left: 8px; }

/* ── Calendar ────────────────────────────────────────────────── */
.calendar {
  background: var(--panel); border: 1px solid var(--border);
  border-radius: 8px;
  overflow-x: auto;
  overflow-y: hidden;
  scrollbar-color: var(--accent) var(--panel-2);
}
.calendar::-webkit-scrollbar { height: 10px; }
.calendar::-webkit-scrollbar-track { background: var(--panel-2); }
.calendar::-webkit-scrollbar-thumb { background: var(--border); border-radius: 5px; }
.calendar::-webkit-scrollbar-thumb:hover { background: var(--accent); }
.calendar-grid {
  display: grid;
  grid-template-columns: 90px repeat({{ calendar.days|length }}, minmax(60px, 1fr));
  font-size: 11px;
  min-width: max-content;
}
.cal-cell.cal-country { position: sticky; left: 0; z-index: 2; }
.cal-cell.cal-header:first-child { position: sticky; left: 0; z-index: 3; }
.cal-cell {
  padding: 5px 3px;
  border-right: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  min-height: 28px;
}
.cal-header { background: var(--panel-2); font-weight: 600; text-align: center; color: var(--text-dim); }
.cal-header.today { color: var(--accent); }
.cal-header.weekend { color: #64748b; }
.cal-country { background: var(--panel-2); font-weight: 600; display: flex; align-items: center; gap: 4px; font-size: 11px; }
.cal-country .flag { font-size: 14px; }
.cal-event {
  display: block;
  padding: 2px 3px; margin: 1px 0;
  border-radius: 3px;
  background: rgba(56, 189, 248, 0.15);
  color: var(--accent);
  font-size: 10px; line-height: 1.25;
  border-left: 2px solid var(--accent);
  cursor: pointer;
  transition: background 0.1s;
}
.cal-event:hover { background: rgba(56, 189, 248, 0.35); }
.cal-event.imp-3 { background: rgba(248, 113, 113, 0.15); color: var(--bad); border-left-color: var(--bad); }
.cal-event.imp-3:hover { background: rgba(248, 113, 113, 0.35); }
.cal-event.imp-2 { background: rgba(251, 191, 36, 0.15); color: var(--warn); border-left-color: var(--warn); }
.cal-event.imp-2:hover { background: rgba(251, 191, 36, 0.35); }
.cal-event.past { opacity: 0.45; }

/* Event detail modal */
.modal-backdrop {
  display: none;
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.6);
  z-index: 100;
  justify-content: center; align-items: center;
}
.modal-backdrop.open { display: flex; }
.modal {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 24px;
  min-width: 320px; max-width: 480px;
  position: relative;
}
.modal .close {
  position: absolute; top: 12px; right: 16px;
  background: none; border: none; color: var(--text-dim);
  font-size: 22px; cursor: pointer; line-height: 1;
}
.modal .close:hover { color: var(--text); }
.modal h3 {
  margin: 0 0 4px 0; font-size: 18px;
  display: flex; align-items: center; gap: 10px;
}
.modal .m-meta { color: var(--text-dim); font-size: 13px; margin-bottom: 16px; }
.modal .m-grid {
  display: grid; grid-template-columns: 110px 1fr;
  gap: 8px 16px; font-size: 13px;
}
.modal .m-grid .label { color: var(--text-dim); }
.modal .m-grid .val { color: var(--text); font-weight: 500; }
.modal .m-note {
  margin-top: 14px; padding-top: 12px;
  border-top: 1px dashed var(--border);
  color: var(--text-dim); font-size: 12px; font-style: italic;
}
.imp-badge {
  display: inline-block; font-size: 11px; padding: 2px 6px;
  border-radius: 4px; font-weight: 600;
}
.imp-badge.imp-3 { background: rgba(248, 113, 113, 0.2); color: var(--bad); }
.imp-badge.imp-2 { background: rgba(251, 191, 36, 0.2); color: var(--warn); }
.imp-badge.imp-1 { background: rgba(56, 189, 248, 0.2); color: var(--accent); }

/* ── Snapshot panels (existing + new) ─────────────────────────── */
.panels {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
  gap: 16px;
}
.panel {
  background: var(--panel); border: 1px solid var(--border);
  border-radius: 8px; padding: 14px 16px;
}
.panel h3 {
  margin: 0 0 10px 0; font-size: 13px; font-weight: 600;
  display: flex; align-items: center; gap: 6px;
  color: var(--text);
}
.panel h3 .flag { font-size: 18px; }
.panel-table { width: 100%; border-collapse: collapse; font-size: 12px; }
.panel-table th, .panel-table td {
  text-align: right; padding: 5px 4px;
  border-bottom: 1px solid var(--border);
}
.panel-table th { color: var(--text-dim); font-weight: 500; font-size: 10px; text-transform: uppercase; letter-spacing: 0.04em; }
.panel-table td.name { text-align: left; color: var(--text); font-weight: 500; }
.panel-table td.name small { color: var(--text-dim); font-weight: 400; display: block; font-size: 10px; }
.surprise-pos { color: var(--good); font-weight: 600; }
.surprise-neg { color: var(--bad); font-weight: 600; }
.surprise-zero { color: var(--neutral); }
.no-data { color: var(--text-dim); font-style: italic; }

/* ── Markets snapshot (new) ──────────────────────────────────── */
.markets {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 12px;
}
.markets .panel { padding: 12px 14px; }
.markets .panel h3 {
  font-size: 12px; color: var(--text-dim); text-transform: uppercase;
  letter-spacing: 0.05em; margin-bottom: 8px;
}
.markets .panel-table td { padding: 4px 3px; }
.markets .panel-table .name { font-size: 11px; }
.markets .panel-table .name .flag { font-size: 13px; margin-right: 4px; }
.markets .value-cell { font-variant-numeric: tabular-nums; font-weight: 600; }
.markets .change-pos { color: var(--bad); font-size: 10px; }
.markets .change-neg { color: var(--good); font-size: 10px; }
.markets .change-zero { color: var(--text-dim); font-size: 10px; }

/* ── Central bank box ────────────────────────────────────────── */
.cb-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 12px;
}
.cb-card {
  background: var(--panel); border: 1px solid var(--border);
  border-radius: 8px; padding: 12px;
  position: relative;
}
.cb-card .cb-flag { font-size: 22px; }
.cb-card .cb-name { font-size: 11px; color: var(--text-dim); margin-top: 2px; }
.cb-card .cb-rate { font-size: 24px; font-weight: 700; margin: 6px 0 2px 0; letter-spacing: -0.02em; }
.cb-card .cb-next { font-size: 11px; color: var(--text-dim); }
.cb-card .cb-next strong { color: var(--accent); }
.cb-card .cb-implied { font-size: 11px; color: var(--text-dim); margin-top: 6px; padding-top: 6px; border-top: 1px dashed var(--border); }
.cb-card .cb-implied strong { color: var(--text); }
.cb-card .implied-delta.hike { color: var(--bad); font-weight: 600; }
.cb-card .implied-delta.cut  { color: var(--good); font-weight: 600; }
.cb-card .implied-delta.flat { color: var(--text-dim); }
.cb-card.imminent { border-color: var(--accent); box-shadow: 0 0 0 1px var(--accent); }

footer {
  margin-top: 48px; padding-top: 16px; border-top: 1px solid var(--border);
  font-size: 11px; color: var(--text-dim); text-align: center;
}
footer a { color: var(--accent); text-decoration: none; }
</style>
</head>
<body>
<div class="container">

<header>
  <h1>Global REIT Macro Dashboard</h1>
  <div class="meta">
    Last update: <strong>{{ build_time }}</strong> KST &nbsp;|&nbsp;
    Calendar: {{ calendar.range_label }}
  </div>
</header>

<!-- ─── 5주 캘린더 ─────────────────────────────────────────── -->
<section>
  <h2>📅 Economic Calendar <small>{{ calendar.range_label }}</small></h2>
  <div class="calendar">
    <div class="calendar-grid">
      <div class="cal-cell cal-header">Country</div>
      {% for day in calendar.days %}
      <div class="cal-cell cal-header {% if day.is_today %}today{% endif %} {% if day.is_weekend %}weekend{% endif %}">
        {{ day.label }}<br>{{ day.weekday }}
      </div>
      {% endfor %}
      {% for country_code, country in countries.items() %}
      <div class="cal-cell cal-country">
        <span class="flag">{{ country.flag }}</span> {{ country_code }}
      </div>
      {% for day in calendar.days %}
      <div class="cal-cell">
        {% for ev in calendar.events_by_country_day.get(country_code, {}).get(day.date, []) %}
        <span class="cal-event imp-{{ ev.importance }} {% if ev.is_past %}past{% endif %}"
              data-name="{{ ev.name }}"
              data-name-ko="{{ ev.name_ko }}"
              data-flag="{{ ev.country_flag }}"
              data-country="{{ ev.country_name }}"
              data-date="{{ ev.date }}"
              data-time="{{ ev.time_kst }}"
              data-cat="{{ ev.category_emoji }} {{ ev.category_ko }}"
              data-imp="{{ ev.importance }}"
              data-note="{{ ev.note }}"
              data-past="{{ ev.is_past|lower }}">
          {{ ev.short_name }}
        </span>
        {% endfor %}
      </div>
      {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>

<!-- Event Detail Modal -->
<div class="modal-backdrop" id="evModalBackdrop">
  <div class="modal">
    <button class="close" onclick="closeEvModal()">&times;</button>
    <h3 id="evModalTitle"></h3>
    <div class="m-meta" id="evModalSubtitle"></div>
    <div class="m-grid" id="evModalGrid"></div>
    <div class="m-note" id="evModalNote" style="display:none"></div>
  </div>
</div>

<script>
(function() {
  const backdrop = document.getElementById('evModalBackdrop');
  const title = document.getElementById('evModalTitle');
  const subtitle = document.getElementById('evModalSubtitle');
  const grid = document.getElementById('evModalGrid');
  const note = document.getElementById('evModalNote');
  const impLabels = {3: '★★★ High', 2: '★★ Medium', 1: '★ Low'};

  document.querySelectorAll('.cal-event').forEach(el => {
    el.addEventListener('click', () => {
      const d = el.dataset;
      title.innerHTML = `${d.flag} <span>${d.name}</span>`;
      const past = d.past === 'true';
      subtitle.textContent = `${d.country} · ${d.nameKo}${past ? ' · 발표 완료' : ' · 예정'}`;
      grid.innerHTML = `
        <div class="label">Date (KST)</div><div class="val">${d.date}${d.time ? ' ' + d.time : ''}</div>
        <div class="label">Category</div><div class="val">${d.cat}</div>
        <div class="label">Importance</div><div class="val"><span class="imp-badge imp-${d.imp}">${impLabels[d.imp] || d.imp}</span></div>
      `;
      if (d.note && d.note.trim()) {
        note.textContent = '📝 ' + d.note;
        note.style.display = '';
      } else {
        note.style.display = 'none';
      }
      backdrop.classList.add('open');
    });
  });

  backdrop.addEventListener('click', (e) => {
    if (e.target === backdrop) closeEvModal();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeEvModal();
  });
})();

function closeEvModal() {
  document.getElementById('evModalBackdrop').classList.remove('open');
}
</script>

<!-- ─── 중앙은행 정책금리 박스 ──────────────────────────────── -->
<section>
  <h2>🏦 Central Bank Policy Rates</h2>
  <div class="cb-grid">
    {% for cb in central_banks %}
    <div class="cb-card {% if cb.is_imminent %}imminent{% endif %}">
      <span class="cb-flag">{{ cb.flag }}</span>
      <div class="cb-name">{{ cb.name }}</div>
      <div class="cb-rate">
        {% if cb.rate is not none %}{{ "%.2f"|format(cb.rate) }}%{% else %}—{% endif %}
      </div>
      <div class="cb-next">
        Next: <strong>{{ cb.next_meeting or "TBD" }}</strong>
        {% if cb.consensus_rate is not none %}
        &middot; cons {{ "%.2f"|format(cb.consensus_rate) }}%
        {% endif %}
      </div>
      {% if cb.implied_1y is not none %}
      <div class="cb-implied" title="1Y OIS = 향후 12개월 평균 정책금리 (시장 거래가 기준)">
        12M 시장: <strong>{{ "%.2f"|format(cb.implied_1y) }}%</strong>
        {% if cb.implied_delta_bp is not none %}
        <span class="implied-delta {% if cb.implied_delta_bp > 5 %}hike{% elif cb.implied_delta_bp < -5 %}cut{% else %}flat{% endif %}">
          {{ "%+d"|format(cb.implied_delta_bp) }}bp
          {% if cb.implied_moves is not none and cb.implied_moves|abs >= 0.3 %}
          (~{{ "%.1f"|format(cb.implied_moves|abs) }} {% if cb.implied_moves > 0 %}인상{% else %}인하{% endif %})
          {% endif %}
        </span>
        {% endif %}
      </div>
      {% endif %}
    </div>
    {% endfor %}
  </div>
</section>

<!-- ─── Markets Snapshot (Daily/Weekly) ───────────────────── -->
{% if markets %}
<section>
  <h2>💹 Markets Snapshot <small>매일 갱신</small></h2>
  <div class="markets">
    {% for cat_id, cat_data in markets.items() %}
    <div class="panel">
      <h3>{{ cat_data.emoji }} {{ cat_data.name_ko }}</h3>
      <table class="panel-table">
        <thead><tr><th style="text-align:left">지표</th><th>Latest</th><th>1D Δ</th><th>Date</th></tr></thead>
        <tbody>
          {% for row in cat_data.rows %}
          <tr>
            <td class="name"><span class="flag">{{ row.flag }}</span>{{ row.name_ko }}</td>
            <td class="value-cell">
              {% if row.value is not none %}{{ ("%%.%df" % row.decimals)|format(row.value) }}{% if row.unit == "%" %}%{% endif %}{% else %}<span class="no-data">—</span>{% endif %}
            </td>
            <td class="{% if row.change_1d and row.change_1d > 0 %}change-pos{% elif row.change_1d and row.change_1d < 0 %}change-neg{% else %}change-zero{% endif %}">
              {% if row.change_1d is not none %}{{ "%+.2f"|format(row.change_1d) }}{% else %}—{% endif %}
            </td>
            <td><small style="color:var(--text-dim)">{{ row.as_of or "—" }}</small></td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% endfor %}
  </div>
</section>
{% endif %}

<!-- ─── 이벤트형 카테고리 패널 (Inflation / Unemployment / Housing / Consumer / Retail) ─── -->
{% for cat_id, cat_block in event_categories.items() %}
{% if cat_block.by_country %}
<section>
  <h2>{{ cat_block.emoji }} {{ cat_block.name_ko }} Snapshot</h2>
  <div class="panels">
    {% for country_code, rows in cat_block.by_country.items() %}
    {% if rows %}
    <div class="panel">
      <h3><span class="flag">{{ countries[country_code].flag }}</span> {{ countries[country_code].name }}</h3>
      <table class="panel-table">
        <thead>
          <tr><th style="text-align:left">Indicator</th><th>Latest</th><th>Prior</th><th>Consensus</th><th>Surprise</th><th>Date</th></tr>
        </thead>
        <tbody>
          {% for r in rows %}
          <tr>
            <td class="name">
              {{ r.name }}
              {% if r.name_ko and r.name_ko != r.name %}<small>{{ r.name_ko }}</small>{% endif %}
            </td>
            <td>{% if r.actual is not none %}{{ ("%%.%df" % r.decimals)|format(r.actual) }}{% if r.unit == "%" %}%{% endif %}{% else %}<span class="no-data">—</span>{% endif %}</td>
            <td>{% if r.prior is not none %}{{ ("%%.%df" % r.decimals)|format(r.prior) }}{% if r.unit == "%" %}%{% endif %}{% else %}<span class="no-data">—</span>{% endif %}</td>
            <td>{% if r.consensus is not none %}{{ ("%%.%df" % r.decimals)|format(r.consensus) }}{% if r.unit == "%" %}%{% endif %}{% else %}<span class="no-data">—</span>{% endif %}</td>
            <td class="{% if r.surprise and r.surprise > 0 %}surprise-pos{% elif r.surprise and r.surprise < 0 %}surprise-neg{% else %}surprise-zero{% endif %}">
              {% if r.surprise is not none %}{{ "%+.2f"|format(r.surprise) }}{% else %}—{% endif %}
            </td>
            <td><small style="color:var(--text-dim)">{{ r.release_date or "—" }}</small></td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% endif %}
    {% endfor %}
  </div>
</section>
{% endif %}
{% endfor %}

<footer>
  Data sources: Bloomberg (xbbg) · FRED · Central Bank official calendars<br>
  Built with Python + Jinja2 · Hosted on GitHub Pages · Updated {{ build_time }} KST
</footer>

</div>
</body>
</html>
